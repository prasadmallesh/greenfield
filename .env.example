# Copy this file to .env and fill in real values (never commit .env).

APP_ENV=staging

# Set to 1 only while fixing a blank HTTP 500; then remove or set back to 0 (do not leave on in production).
APP_DEBUG=0

# When 1 (default), the app must not send email, SMS, or WhatsApp — stubs only.
APP_DISABLE_OUTBOUND_COMMUNICATIONS=1

# URL path prefix for all routes (no trailing slash). Leave empty when the site document root is this project's public/ folder.
# Example: if the app is served at https://example.com/msoft/public/ set APP_BASE_PATH=/msoft/public
APP_BASE_PATH=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
